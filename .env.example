# Local dev: same-origin proxy (see next.config.mjs) avoids CORS when the app is localhost:3001.
NEXT_PUBLIC_API_URL=/api/proxy
NEXT_PUBLIC_LARAVEL_ORIGIN=http://127.0.0.1:8008
# Optional: server-side / API_URL when using relative NEXT_PUBLIC_API_URL (defaults to 127.0.0.1:8008/api).
# API_URL=http://127.0.0.1:8008/api
# Alternative: call Laravel directly (ensure CORS / same host as the browser tab).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8008/api
